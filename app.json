{
	"expo": {
		"name": "Dongi",
		"slug": "dongi",
		"version": "1.0.0",
		"orientation": "portrait",
		"icon": "./assets/images/icon.png",
		"scheme": "dongi",
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"ios": {
			"supportsTablet": true,
			"bundleIdentifier": "com.dongi.dongi",
			"infoPlist": {
				"NSLocationWhenInUseUsageDescription": "This app needs access to location services to show you nearby places.",
				"NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to location services to show you nearby places and provide background navigation.",
				"NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera"
			}
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/images/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			},
			"package": "com.dongi.dongi",
			"googleServicesFile": "./google-services.json",
			"permissions": [
				"android.permission.CAMERA",
				"android.permission.RECORD_AUDIO"
			]
		},
		"web": {
			"bundler": "metro",
			"output": "static",
			"favicon": "./assets/images/favicon.png"
		},
		"plugins": [
			"expo-router",
			[
				"expo-location",
				{
					"locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location."
				}
			],
			[
				"expo-splash-screen",
				{
					"image": "./assets/images/icon.png",
					"resizeMode": "cover",
					"backgroundColor": "#18658B",
					"imageWidth": "159"
				}
			],
			[
				"expo-camera",
				{
					"cameraPermission": "Allow $(PRODUCT_NAME) to access your camera to take a picture for identity verification",
					"microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone",
					"recordAudioAndroid": false
				}
			],
			[
				"expo-image-picker",
				{
					"photosPermission": "ALlow ${PRODUCT_NAME} to access your photos to let you set your business logo."
				}
			],
			[
				"expo-document-picker",
				{
					"iCloudContainerEnvironment": "Production"
				}
			],
			"expo-font",
			[
				"expo-notifications",
				{
					"color": "#18658B",
					"defaultChannel": "default",
					"sounds": ["./assets/sounds/dongi.wav"],
					"enableBackgroundRemoteNotifications": true
				}
			]
		],
		"experiments": {
			"typedRoutes": true
		},
		"extra": {
			"eas": {
				"projectId": "614c7a44-266d-4516-aa63-a9eca113e337"
			},
			"router": {
				"origin": false
			}
		},
		"owner": "dongifix"
	}
}
